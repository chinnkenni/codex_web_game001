{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codex-web-game001",
  "main": "./src/worker.js",
  "compatibility_date": "2026-06-16",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true
    }
  }
}
